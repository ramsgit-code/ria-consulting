# Database (Supabase Postgres — use connection pooler for Vercel)
# Example: postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Admin login (use npm run admin:hash for ADMIN_PASSWORD_HASH)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# Go High Level
GHL_API_KEY=your_api_key_here
GHL_LOCATION_ID=your_location_id_here
GHL_PIPELINE_ID=your_pipeline_id_here
GHL_STAGE_NUEVO_LEAD=your_stage_id_here

# GHL Custom Field IDs
GHL_FIELD_SECTOR=
GHL_FIELD_TIPO_NEGOCIO=
GHL_FIELD_TAMANO_EQUIPO=
GHL_FIELD_VOLUMEN_LEADS=
GHL_FIELD_CRM_ACTUAL=
GHL_FIELD_USA_WHATSAPP=
GHL_FIELD_TIEMPO_PROPUESTA=
GHL_FIELD_PROBLEMA=
GHL_FIELD_URGENCIA=
GHL_FIELD_PRESUPUESTO=
GHL_FIELD_LEAD_SCORE=
GHL_FIELD_LEAD_TIER=
GHL_FIELD_COMO_CONOCISTE=
GHL_FIELD_NOTAS=

# Calendario
NEXT_PUBLIC_CALENDAR_URL=https://your-calendar-link.com

# Blog agent (optional)
ANTHROPIC_API_KEY=
